def dMdx(M):
    term1 = ((2 * Cf * gamma)/Dh)
    term2 = (M**3)/(1 - M**2)
    term3 = (1 + (gamma-1)/2 * M**2)
    return term1 * term2 * term3

def rk4M(M):
    k1 = dMdx(M)
    k2 = dMdx(M + 0.5*dx*k1)
    k3 = dMdx(M + 0.5*dx*k2)
    k4 = dMdx(M + dx*k3)

    Mnew = M + (dx/6)*(k1 + 2*k2 + 2*k3 + k4)
    
    return Mnew
