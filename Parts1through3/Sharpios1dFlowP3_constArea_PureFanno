def T_Tstar (M):
    return (gamma + 1)/(2 + (gamma-1) *M**2)
def P_Pstar (M):
    return (1/M) * np.sqrt((gamma + 1)/(2 + (gamma - 1) * M**2))
def Pt_Ptstar (M):
    return (1/M) * ((2 + (gamma - 1) * M**2)/(gamma + 1))**((gamma+1)/(2*(gamma-1)))

Tstar = T0/T_Tstar(M0)
Pstar = P0/P_Pstar(M0)
PtStar = P0/Pt_Ptstar(M0)

def fanno_MachRelation(M1,M2):
    part1=(gamma + 1)/(2 * gamma) * np.log((2 + (gamma -1) * M2**2)/(2 + (gamma-1) * M1**2))
    part2 = -(1/gamma) * ((1/M2**2)-(1/M1**2))
    part3 = -((gamma+1)/(2*gamma)) * np.log((M2**2)/M1**2)
    return part1 + part2 + part3

def fM(M2,M1):  #M2 unknown so it goes first (for fsolve reasons)
    return fanno_MachRelation(M1,M2) - ((f_darcy * dx)/Dh)

def pt1_pt2(M1,M2):
    return (M1/M2) * ((2 + (gamma-1) * M2**2)/(2 + (gamma-1) * M1**2))**((gamma+1)/(2 * (gamma-1)))

