def mNum(v,a):
    M = v/a
    return M

def soS(T):

    a = np.sqrt(gamma * R * T)
    return a

def dVdx(M, T,V,localdHtdx, localMdot,dMdotdx):
    part1 = ((V/((1 - M**2) * cp * T)) * localdHtdx)
    part2 = (gamma * M**2)/(2 * (1 - M**2))
    part3 = ((4*Cf * V/Dh) - ((Vinj/localMdot) * dMdotdx))
    return part1 + part2 * part3

def dPdx(M, T, P, V, localdHtdx, localMdot, dMdotdx):
    part1 = (-((gamma * M**2 * P)/((1-M**2) * cp * T)) * localdHtdx)
    part2 = ((gamma * M**2 * (1 + (gamma-1)*M**2))/(2 * (1 - M**2)))
    part3 = ((4*Cf * P/Dh) - (2 * ((Vinj * P)/localMdot * V) * dMdotdx))
    return part1 - part2 * part3

def rhonP1(rho,V1, V2):
    denNP1 = (rho * V1)/(V2)
    return denNP1

#will do forward eulers first 
def vnP1(dvdx, v):
    vNP1 = v + (dvdx * dx)
    return vNP1

def pnP1(dpdx, P):
    pNP1 = P + (dpdx * dx)
    return pNP1


